# ── Supabase (required) ──────────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role key — NEVER expose to client. Used for admin operations only.
# Get from: Supabase Dashboard → Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── OpenAI (optional — for enhanced AI insights) ─────────────────────────────
# If set, AI insights will use GPT-4o-mini for natural language generation
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ── Razorpay (for India payments) ────────────────────────────────────────────
# Get from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=...
RAZORPAY_WEBHOOK_SECRET=...
# Create a recurring plan in Razorpay Dashboard → Subscriptions → Plans
# Set amount to 49900 (₹499 in paise), interval=monthly
RAZORPAY_PLAN_ID=plan_...

# ── Sentry (optional — for error monitoring) ─────────────────────────────────
# Get from: https://sentry.io
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
SENTRY_AUTH_TOKEN=...
